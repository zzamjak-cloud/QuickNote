# QuickNote v3 인증 설정. infra/cdk-outputs.json 의 값으로 채운다.
VITE_COGNITO_REGION=ap-northeast-2
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_HOSTED_UI_DOMAIN=quicknote-auth.auth.ap-northeast-2.amazoncognito.com
VITE_COGNITO_WEB_CLIENT_ID=
VITE_COGNITO_DESKTOP_CLIENT_ID=
VITE_AUTH_REDIRECT_WEB=http://localhost:5173/auth/callback
VITE_AUTH_REDIRECT_DESKTOP=quicknote://auth/callback

# v4 동기화/이미지 (infra/cdk-outputs.json 의 값으로 채움)
# 로컬(npm run dev)과 프로덕션(Vercel)이 같은 AppSync·같은 Cognito Web 클라이언트를 써야
# 웹 간 동기화가 동작한다. VITE_APPSYNC_ENDPOINT·VITE_COGNITO_* 는 배포 환경과 일치시킬 것.
VITE_APPSYNC_ENDPOINT=
# Page.blockComments 는 프론트에서 항상 동기화한다. 스키마에 필드가 없으면 CDK 배포를 먼저 맞출 것.
VITE_S3_REGION=ap-northeast-2
VITE_S3_BUCKET_NAME=

# 지도 링크 메타데이터(서버리스 /api/bookmark)
# Google 지도 주소/좌표 -> 주소/썸네일 보강
GOOGLE_MAPS_API_KEY=
# Naver 지도 링크(query/title) -> 장소명/주소 보강
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 실시간 공동 편집. 미설정이면 협업 OFF. 배포된 WS 스택의 wss URL.
# ⚠️ 데스크톱(Tauri) 빌드도 이 값을 반드시 웹(Vercel)과 동일하게 주입해야 한다.
#    비면 데스크톱은 협업 OFF 가 되어 REST page.doc 만 갱신 → 협업 ON 인 웹과 권위가 갈려
#    desktop↔web 동기화가 끊긴다. (CI: build.yml 의 GH secret VITE_COLLAB_WS_URL)
VITE_COLLAB_WS_URL=
# 협업 활성 페이지 id 콤마 구분. "*" 이면 전체. 점진 롤아웃용.
VITE_COLLAB_ENABLED_PAGE_IDS=
# 협업 활성 데이터베이스 id 콤마 구분. "*" 이면 전체.
VITE_COLLAB_ENABLED_DB_IDS=
# 협업 룸/IndexedDB 키 세대. 협업을 껐다 켜거나 권위 비대칭을 정리할 때 올린다(v3→v4…).
# 웹·데스크톱을 반드시 같은 값으로 맞춰야 같은 Y 룸에서 수렴한다. 미설정 시 코드 기본값 사용.
VITE_COLLAB_ROOM_EPOCH=

# AI 프록시 (CDK AiProxyUrl output). 미설정이면 AI 관련 UI 전체 비노출.
# 배포 시 vercel.json CSP connect-src 에 이 호스트를 추가해야 한다 (dev/prod 각각).
VITE_AI_URL=
